---
import { getAssetPath } from "../utils/paths.js";

const categorias = [
  {
    titulo: "Platería y plata maciza",
    imagen: getAssetPath("assets/plateria.jpg"),
    descripcion:
      "Bandejas, mates, juegos de té, cubiertos, jarros, fuentes, candelabros y marcos de plata.",
  },
  {
    titulo: "Muebles antiguos",
    imagen: getAssetPath("assets/mueble.webp"),
    descripcion:
      "Armarios, mesas, sillas, consolas y mobiliario de época en buen estado.",
  },
  {
    titulo: "Relojes de época",
    imagen: getAssetPath("assets/reloj.webp"),
    descripcion:
      "Relojes de péndulo, de bolsillo, de pared y relojes de colección.",
  },
  {
    titulo: "Arte y esculturas",
    imagen: getAssetPath("assets/arte.jpg"),
    descripcion:
      "Cuadros, pinturas al óleo, grabados y esculturas con valor histórico o artístico.",
  },
  {
    titulo: "Objetos decorativos",
    imagen: getAssetPath("assets/objeto.jpg"),
    descripcion:
      "Lámparas, espejos, porcelanas, cristalería y elementos decorativos clásicos.",
  },
];
---

<section class="bg-white px-8 py-16">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-4 text-center font-bold text-amber-800 text-3xl">
      ¿Qué compramos?
    </h2>
    <p class="mb-10 text-center text-gray-600 text-lg">
      Adquirimos todo tipo de antigüedades. Valoración gratuita y pago inmediato
      al contado.
    </p>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        categorias.map((cat) => (
          <div class="group relative overflow-hidden rounded-xl shadow-md">
            <img
              src={cat.imagen}
              alt={cat.titulo}
              class="h-56 w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent" />
            <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
              <h3 class="mb-1 font-semibold text-xl">{cat.titulo}</h3>
              <p class="text-sm text-gray-200">{cat.descripcion}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href="https://wa.link/ovsda9"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-lg bg-amber-600 px-8 py-3 text-white transition-colors text-lg hover:bg-amber-700"
      >
        Solicitar tasación gratuita
      </a>
    </div>
  </div>
</section>
